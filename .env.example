# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
JWT_SECRET=your-jwt-secret
NEXTAUTH_SECRET=your-random-secret-string
NEXTAUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your-key
# Optional: Use custom domain once verified (e.g. Handle <noreply@handlejobs.com>). Default: onboarding@resend.dev
# RESEND_FROM_EMAIL=Handle <noreply@handlejobs.com>

# AI (Groq) - required for job application automation
GROQ_API_KEY=your-groq-api-key

# Local dev: run `npx playwright install chromium` before applying to jobs
